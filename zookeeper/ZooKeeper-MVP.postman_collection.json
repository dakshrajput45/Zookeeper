{
  "info": {
    "name": "ZooKeeper MVP - Functional API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "ZooKeeper health check",
      "request": { "method": "GET", "url": "http://localhost:8080/health" }
    },
    {
      "name": "Register node-1 in ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-1\",\"address\":\"http://localhost:9001\"}" },
        "url": "http://localhost:8080/nodes/register"
      }
    },
    {
      "name": "Register node-2 in ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-2\",\"address\":\"http://localhost:9002\"}" },
        "url": "http://localhost:8080/nodes/register"
      }
    },
    {
      "name": "Register node-3 in ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-3\",\"address\":\"http://localhost:9003\"}" },
        "url": "http://localhost:8080/nodes/register"
      }
    },
    {
      "name": "Send heartbeat for node-1 to ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-1\"}" },
        "url": "http://localhost:8080/nodes/heartbeat"
      }
    },
    {
      "name": "Send heartbeat for node-2 to ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-2\"}" },
        "url": "http://localhost:8080/nodes/heartbeat"
      }
    },
    {
      "name": "Send heartbeat for node-3 to ZooKeeper",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"node_id\":\"node-3\"}" },
        "url": "http://localhost:8080/nodes/heartbeat"
      }
    },
    {
      "name": "Get current leader from ZooKeeper",
      "request": { "method": "GET", "url": "http://localhost:8080/leader" }
    },
    {
      "name": "Get cluster liveness from ZooKeeper",
      "request": { "method": "GET", "url": "http://localhost:8080/nodes/alive" }
    },
    {
      "name": "Get latest election state from ZooKeeper",
      "request": { "method": "GET", "url": "http://localhost:8080/election/state" }
    },
    {
      "name": "Write key/value via ZooKeeper quorum flow",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"key\":\"k1\",\"value\":\"v1\"}" },
        "url": "http://localhost:8080/write"
      }
    },
    {
      "name": "Read key through ZooKeeper leader route",
      "request": { "method": "GET", "url": "http://localhost:8080/read?key=k1" }
    },
    {
      "name": "Get replication state from ZooKeeper",
      "request": { "method": "GET", "url": "http://localhost:8080/replication/state" }
    },

    {
      "name": "Node-1 - GET /health",
      "request": { "method": "GET", "url": "http://localhost:9001/health" }
    },
    {
      "name": "Node-1 - POST /vote-request",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"term\":1,\"candidate_ids\":[\"node-1\",\"node-2\",\"node-3\"]}" },
        "url": "http://localhost:9001/vote-request"
      }
    },
    {
      "name": "Node-1 - POST /replication/append",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"index\":1,\"term\":1,\"leader_id\":\"node-1\",\"key\":\"k1\",\"value\":\"v1\"}" },
        "url": "http://localhost:9001/replication/append"
      }
    },
    {
      "name": "Node-1 - GET /internal/read?key=k1",
      "request": { "method": "GET", "url": "http://localhost:9001/internal/read?key=k1" }
    },
    {
      "name": "Node-1 - POST /admin/heartbeat/stop",
      "request": { "method": "POST", "url": "http://localhost:9001/admin/heartbeat/stop" }
    },
    {
