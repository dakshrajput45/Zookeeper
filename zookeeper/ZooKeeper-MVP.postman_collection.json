        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"index\":1,\"term\":1,\"leader_id\":\"node-1\",\"key\":\"k1\",\"value\":\"v1\"}" },
        "url": "http://localhost:9003/replication/append"
      }
    },
    {
      "name": "Node-3 - GET /internal/read?key=k1",
      "request": { "method": "GET", "url": "http://localhost:9003/internal/read?key=k1" }
    },
    {
