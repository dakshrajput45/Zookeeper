      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"term\":1,\"candidate_ids\":[\"node-1\",\"node-2\",\"node-3\"]}" },
        "url": "http://localhost:9002/vote-request"
      }
    },
    {
      "name": "Node-2 - POST /replication/append",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"index\":1,\"term\":1,\"leader_id\":\"node-1\",\"key\":\"k1\",\"value\":\"v1\"}" },
        "url": "http://localhost:9002/replication/append"
      }
    },
    {
      "name": "Node-2 - GET /internal/read?key=k1",
      "request": { "method": "GET", "url": "http://localhost:9002/internal/read?key=k1" }
    },
    {
      "name": "Node-2 - POST /admin/heartbeat/stop",
      "request": { "method": "POST", "url": "http://localhost:9002/admin/heartbeat/stop" }
    },
    {
      "name": "Node-2 - POST /admin/heartbeat/start",
      "request": { "method": "POST", "url": "http://localhost:9002/admin/heartbeat/start" }
    },
    {
      "name": "Node-2 - POST /admin/shutdown",
      "request": { "method": "POST", "url": "http://localhost:9002/admin/shutdown" }
    },

    {
      "name": "Node-3 - GET /health",
      "request": { "method": "GET", "url": "http://localhost:9003/health" }
    },
    {
